  <Box sx={{ display: 'flex', flexDirection: 'column', gap: 0, minWidth: 0 }}>
                <Paper
                  elevation={1}
                  sx={{
                    overflow: 'auto',
                    borderRadius: 3,
                    width: '100%',
                    border:0.5
                  }}
                >
                  <Table
                    stickyHeader
                    sx={{
                      width: '100%',
                      borderCollapse: 'separate',
                      borderSpacing: 0,

                      '& .MuiTableCell-root': {
                        py: 0.55,
                        px: 1.5,
                        whiteSpace: 'nowrap',
                        verticalAlign: 'middle',
                      },
                    }}
                  >
                    <TableHead>
                      <TableRow>
                        {showMrnColumn && (
                          <TableCell
                            sx={{
                              ...headerCellSx,
                              minWidth: { xs: 80, sm: 120 },
                              textAlign: 'left',
                            }}
                          >
                            <Link
                              component="button"
                              underline="none"
                              sx={{
                                display: 'inline-flex',
                                alignItems: 'center',
                                gap: 0.5,
                                maxWidth: '100%',
                              }}
                              onClick={() => {
                                const isAsc = orderBy === 'mrn' && order === 'asc';
                                setOrder(isAsc ? 'desc' : 'asc');
                                setOrderBy('mrn');
                                setServerPageIndex(1);
                              }}
                            >
                              MRN
                              <ArrowDropDownIcon
                                sx={{
                                  transition: '0.2s',
                                  transform:
                                    orderBy === 'mrn' && order === 'asc'
                                      ? 'rotate(180deg)'
                                      : 'rotate(0deg)',
                                  flexShrink: 0,
                                }}
                              />
                            </Link>
                          </TableCell>
                        )}

                        {showNameColumn && (
                          <TableCell
                            sx={{
                              minWidth: { xs: 120, sm: 180 },
                              textAlign: 'left',
                            }}
                          >
                            <Link
                              component="button"
                              underline="none"
                              sx={{
                                display: 'inline-flex',
                                alignItems: 'center',
                                gap: 0.5,
                                fontWeight: 600,
                                maxWidth: '100%',
                                whiteSpace: 'nowrap',
                                overflow: 'hidden',
                                textOverflow: 'ellipsis',
                              }}
                              onClick={() => {
                                const isAsc = orderBy === 'name' && order === 'asc';
                                setOrder(isAsc ? 'desc' : 'asc');
                                setOrderBy('name');
                                setServerPageIndex(1);
                              }}
                            >
                              Name
                              <ArrowDropDownIcon
                                sx={{
                                  transform:
                                    orderBy === 'name' && order === 'asc'
                                      ? 'rotate(180deg)'
                                      : 'rotate(0deg)',
                                  transition: '0.2s',
                                  flexShrink: 0,
                                }}
                              />
                            </Link>
                          </TableCell>
                        )}

                        {showContactInfoColumn && (
                          <TableCell
                            sx={{
                              display: { md: 'table-cell' },
                            }}
                          >
                            Contact Information
                          </TableCell>
                        )}

                        {showAlertsColumn && (
                          <TableCell
                            sx={{
                              display: { xs: 'none', sm: 'table-cell' },
                            }}
                          >
                            {viewMode === 'ONBOARDED' && (
                              <Box sx={{ display: 'flex', alignItems: 'center', gap: 0.5 }}>
                                Alerts
                                <Tooltip title={showAlertsLegend ? "Hide alert guide" : "Show alert guide"}>
                                  <IconButton onClick={() => setShowAlertsLegend((p) => !p)}>
                                    <Info size={15} />
                                  </IconButton>
                                </Tooltip>
                              </Box>
                            )}
                          </TableCell>
                        )}

                        {showAcuityColumn && (
                          <TableCell
                            sx={{ display: { xs: 'none', sm: 'table-cell' } }}
                          >
                            <Link
                              component="button"
                              underline="none"
                              sx={{
                                display: 'inline-flex',
                                gap: 0.5,
                                width: '100%',
                                fontWeight: 600,
                              }}
                              onClick={() => {
                                const isAsc = orderBy === 'acuity' && order === 'asc';
                                setOrder(isAsc ? 'desc' : 'asc');
                                setOrderBy('acuity');
                                setServerPageIndex(1);
                              }}
                            >
                              Acuity
                              <ArrowDropDownIcon
                                sx={{
                                  transform:
                                    orderBy === 'acuity' && order === 'asc'
                                      ? 'rotate(180deg)'
                                      : 'rotate(0deg)',
                                  transition: '0.2s',
                                  flexShrink: 0,
                                }}
                              />
                            </Link>
                          </TableCell>
                        )}

                        {showEnrolledProgramColumn && (
                          <TableCell
                            sx={{
                              display: { xs: 'none', sm: 'table-cell' },
                            }}
                          >
                            Care Program
                          </TableCell>
                        )}

                        {showStatusColumn && (
                          <TableCell
                            sx={{
                              // minWidth: { xs: 80, sm: 120 },
                              whiteSpace: 'nowrap',
                            }}
