                            onRetry={() => void fetchEventTypes()}
                          />
                        );
                      // return <PatientEvents patientId={patientDBId} />

                      case 'reports':
                        return bundle ? <DiagnosticReport bundle={bundle} /> : null;

                      case 'documents':
                        return bundle ? <PatientDocuments bundle={bundle} /> : null;

                      case 'adtRecords':
                        return (
                          <ADTRecords
                            response={{
                              data: adtRecords,
                              meta: {
                                totalItems: adtTotalItems,
                                pageIndex: adtPage,
                                totalPages: adtTotalPages,
                              },
                            }}
                            onPageChange={(page) => {
                              setAdtPage(page);
                              fetchADT(page);
                            }}
                          />
                        );

                      case "nutrition":
                        return (
                          <Box>
                            <Box>
                              <Tabs
                                value={ordersSubTab}
                                onChange={(_, val) => setOrdersSubTab(val)}
                                variant="scrollable"
                                slotProps={{
                                  indicator: {
                                    sx: {
                                      top: 0,
                                      bottom: "unset",
                                      height: 2,
                                      bgcolor: "primary.main",
                                      borderTopLeftRadius: 2,
                                      borderTopRightRadius: 2,
                                    },
                                  },
                                }}
                                sx={{
                                  px: 1,
                                  minHeight: "auto",
                                  "& .MuiTab-root": {
                                    textTransform: "none",
                                    minHeight: "auto",
                                    px: 2,
                                    py: 1.2,
                                    mx: 0.5,
                                    fontSize: 13,
                                    fontWeight: 500,
                                    color: "#555",
                                    "& svg": {
                                      fontSize: 18,
                                      mr: 1,
                                      color: "#888",
                                    },
                                  },
                                  "& .Mui-selected": {
                                    bgcolor: "#e3f2fd",
                                    color: "primary.main",
                                    "& svg": {
                                      color: "primary.main",
                                    },
                                  },
                                }}
                              >
                                <Tab
                                  label={
                                    <Stack sx={{ direction: "row", alignItems: "center", }} spacing={1}>
                                      <RestaurantIcon />
                                      <Typography variant="body2">
                                        Nutrition Orders
                                      </Typography>
                                    </Stack>
                                  }
                                />

                                <Tab
                                  label={
                                    <Stack sx={{ direction: "row", alignItems: "center" }} spacing={1}>
                                      <Pill size={16} strokeWidth={3} />
                                      <Typography variant="body2">
                                        Supplement Orders
                                      </Typography>
                                    </Stack>
                                  }
                                />
                              </Tabs>

                              <Divider sx={{ mt: 0, mb: 4 }} />
                            </Box>

                            {ordersSubTab === 0 ? (
                              <Nutrition
                                patientId={patinentId}
                                refreshToken={nutritionRefreshToken}
                              />
                            ) : (
                              <SupplementOrders
                                patientId={patinentId}
                                refreshToken={nutritionRefreshToken}
                              />
                            )}
                          </Box>
                        );
                      case 'careprofile':
                        return <Careprofile response={bundle} />;

                      case "alerts":
                        return (
                          <PatientAlerts
                            patientId={patientDBId}
                            patientName={name}
                            items={alertsItems}
                            hasMore={alertsHasMore}
                            counts={alertsCounts}
                            filter={alertsFilter}
                            loading={alertsLoading}
                            loadingMore={alertsLoadingMore}
                            error={alertsError}
                            onFilterChange={(v) => {
                              setAlertsFilter(v);
                              refreshAlerts(v);
                            }}
                            onLoadMore={() => {
                              if (alertsLoading || alertsLoadingMore || !alertsHasMore) return;
                              void fetchPatientAlerts(alertsPageIndex + 1, "append");
                            }}
                            onRetry={() => refreshAlerts()}
                          />
                        );

                      case 'pccCarePlan': {
                        const careplanBlock = tabData?.pccCarePlan?.careplan;
                        const kardexBlock = tabData?.pccCarePlan?.kardex;

                        const isCareplan = pccSubTab === 0;
                        const activeLoading = isCareplan ? loadingTabs[PCC_CAREPLAN_KEY] : loadingTabs[PCC_KARDEX_KEY];
                        const activeError = isCareplan ? errorTabs[PCC_CAREPLAN_KEY] : errorTabs[PCC_KARDEX_KEY];

                        return (
                          <Box>
                            <Tabs
                              value={pccSubTab}
                              onChange={(_, val) => {
                                setPccSubTab(val);

                                if (
                                  val === 1 &&
                                  !tabData?.pccCarePlan?.kardex &&
                                  !loadingTabs[PCC_KARDEX_KEY]
                                ) {
                                  void fetchPccCareplanKardex(1);
                                }
                                if (
                                  val === 0 &&
                                  !tabData?.pccCarePlan?.careplan &&
                                  !loadingTabs[PCC_CAREPLAN_KEY]
                                ) {
                                  void fetchPccCareplan(1);
                                }
                              }}
                              variant="scrollable"
                              slotProps={{
                                indicator: {
                                  sx: {
                                    top: 0,
                                    bottom: "unset",
                                    height: 2,
                                    bgcolor: "primary.main",
                                    borderTopLeftRadius: 2,
                                    borderTopRightRadius: 2,
                                  },
                                },
                              }}
                              sx={{
                                px: 1,
                                minHeight: "auto",
                                "& .MuiTab-root": {
                                  textTransform: "none",
                                  minHeight: "auto",
                                  px: 2,
                                  py: 1.2,
                                  mx: 0.5,
                                  fontSize: 13,
                                  fontWeight: 500,
                                  color: "#555",
                                },
                                "& .Mui-selected": {
                                  bgcolor: "#e3f2fd",
                                  color: "primary.main",
                                },
                              }}
                            >
                              <Tab
                                label={
                                  <Stack sx={{ direction: "row", alignItems: "center", }} spacing={1}>
                                    <LocalHospital />
                                    <Typography variant="body2">
                                      Care plan
                                    </Typography>
                                  </Stack>
                                }
                              />

                              <Tab
                                label={
                                  <Stack sx={{ direction: "row", alignItems: "center", }} spacing={1}>
                                    <FormatListBulleted />
                                    <Typography variant="body2">
                                      Care plan kardex
                                    </Typography>
                                  </Stack>
                                }
                              />
                            </Tabs>

                            <Divider sx={{ mt: 0, mb: 2 }} />

                            {activeLoading && renderSkeletonForTab("pccCarePlan")}

                            {!activeLoading && !!activeError && (
                              <Alert
                                severity="error"
                                action={
                                  <Button
                                    color="inherit"
                                    size="small"
                                    onClick={() => {
                                      if (isCareplan) void fetchPccCareplan(1);
                                      else void fetchPccCareplanKardex(1);
                                    }}
                                  >
                                    Retry
                                  </Button>
                                }
                              >
                                {activeError}
                              </Alert>
                            )}

                            {!activeLoading && !activeError && (
                              <>
                                {isCareplan ? (
                                  <PccCareplanRecords
                                    response={careplanBlock}
                                    onPageChange={(page) => void fetchPccCareplan(page)}
                                  />
                                ) : (
                                  <CareplanKardexRecords
                                    response={kardexBlock}
                                    onPageChange={(page) => void fetchPccCareplanKardex(page)}
                                  />
                                )}
                              </>
                            )}
                          </Box>
                        );
                      }

                      case 'episodesOfCare':
                        return (
                          <EpisodeOfCareRecords
                            response={bundle}
                            onPageChange={(page) => void fetchCareEpisodeOfCare(page)}
                          />
                        );

                      case 'incidents':
                        return <IncidentList rows={incidentRows} />;

                      case 'progressNotes':
                        return (
                          <ProgressNotes
                            response={{
                              data: progressRecords,
                              meta: {
                                totalItems: progressTotalItems,
                                pageIndex: progressPage,
                                totalPages: progressTotalPages,
                              },
                            }}
                            onPageChange={(page) => {
                              setProgressPage(page);
                              fetchProgress(page);
                            }}
                            onDetailsError={handleProgressDetailsError}
                            patientHealthLakeId={patientId}
                            onRefresh={refreshProgressRecords}
                          />
                        );

                      case 'contacts':
                        return (
                          <EmergencyContactsRecords
                            response={{
                              data: emergencyContacts,
                              meta: {
                                pageIndex: emergencyMeta.pageIndex,
                                totalPages: emergencyMeta.totalPages,
                                totalItems: emergencyMeta.totalItems,
                              },
                            }}
                            onPageChange={(page) => void fetchEmergencyContanct(page)}
                          />
                        );

                      case 'coverage':
                        return <Coverage bundle={tabData.coverage} />;


                      case 'adl': {
                        const assessmentBundle = tabData?.adl?.assessment;
                        const scoreBundle = tabData?.adl?.score;

                        const isAssessment = adlSubTab === 0;
                        const activeLoading = isAssessment ? loadingTabs[ADL_ASSESSMENT_KEY] : loadingTabs[ADL_SCORE_KEY];
                        const activeError = isAssessment ? errorTabs[ADL_ASSESSMENT_KEY] : errorTabs[ADL_SCORE_KEY];

                        return (
                          <Box>
                            <Tabs
                              value={adlSubTab}
                              onChange={(_, val) => {
                                setAdlSubTab(val);

                                if (val === 1 && !tabData?.adl?.score && !loadingTabs[ADL_SCORE_KEY]) {
                                  void fetchAdlScore();
                                }
                                if (val === 0 && !tabData?.adl?.assessment && !loadingTabs[ADL_ASSESSMENT_KEY]) {
                                  void fetchAdlAssessment();
                                }
                              }}
                              variant="scrollable"
                              slotProps={{
                                indicator: {
                                  sx: {
                                    top: 0,
                                    bottom: "unset",
                                    height: 2,
                                    bgcolor: "primary.main",
                                    borderTopLeftRadius: 2,
                                    borderTopRightRadius: 2,
                                  },
                                },
                              }}
                              sx={{
                                px: 1,
                                minHeight: "auto",
                                "& .MuiTab-root": {
                                  textTransform: "none",
                                  minHeight: "auto",
                                  px: 2,
                                  py: 1.2,
                                  mx: 0.5,
                                  fontSize: 13,
                                  fontWeight: 500,
                                  color: "#555",
                                },
                                "& .Mui-selected": {
                                  bgcolor: "#e3f2fd",
                                  color: "primary.main",
                                },
                              }}
                            >
                              <Tab
                                label={
                                  <Stack sx={{ direction: "row", alignItems: "center", }} spacing={1}>
                                    <ChecklistIcon />
                                    <Typography variant="body2">
                                      ADL Assessment
                                    </Typography>
                                  </Stack>
                                }
                              />

                              <Tab
                                label={
                                  <Stack sx={{ direction: "row", alignItems: "center", }} spacing={1}>
                                    <FormatListBulleted />
                                    <Typography variant="body2">
                                      ADL Score
                                    </Typography>
                                  </Stack>
                                }
                              />
                            </Tabs>

                            <Divider sx={{ mt: 0, mb: 2 }} />

                            {activeLoading && renderSkeletonForTab('adl')}

                            {!activeLoading && !!activeError && (
                              <Alert
                                severity="error"
                                action={
                                  <Button
                                    color="inherit"
                                    size="small"
                                    onClick={() => {
                                      if (isAssessment) void fetchAdlAssessment();
                                      else void fetchAdlScore();
                                    }}
                                  >
                                    Retry
                                  </Button>
                                }
                              >
                                {activeError}
                              </Alert>
                            )}

                            {!activeLoading && !activeError && (
                              <>
                                {isAssessment ? (
                                  <AdlAssessment fhirResponse={assessmentBundle} />
                                ) : (
                                  <AdlScore fhirResponse={scoreBundle} />
                                )}
                              </>
                            )}
                          </Box>
                        );
                      }

                      default:
                        return null;
                    }
                  })()}
                </Suspense>
              </TabPanel>
            ))}
          </Card>
        </Stack>
      </Grid>

      {/* Unresolved alerts / analysis errors banner - full width, above the nav + content */}
      {
        ((picklist?.tenant === "clinic" && unresolvedAlertsCount > 0) || analysisError) && (
          <Grid size={12} ref={activityContainerRef}>
            <Stack spacing={1}>
              {picklist?.tenant === "clinic" && unresolvedAlertsCount > 0 && (
                <Alert
                  severity="error"
                  sx={{ borderRadius: 2.4 }}
                  action={
                    <Button
                      size="small"
                      variant="outlined"
                      sx={{
                        textTransform: "none",
                        fontWeight: 500,
                        color: "error.main",
                        borderColor: "error.main",
                        mx: 2,
                        bgcolor: "#ffffff",
                      }}
                      onClick={() => {
                        setSelectedTabId("alerts");
                        handleTabClick("alerts");
                      }}
                    >
                      View alerts
                    </Button>
                  }
                >
                  {name} has <b>{unresolvedAlertsCount}</b> unresolved alerts. Please click on view alerts to review them.
                </Alert>
              )}
              {analysisError && <Alert severity="warning">{analysisError}</Alert>}
            </Stack>
          </Grid>
        )
      }
    </Grid >
  );
}
