    period,
    selectedVital,
    patientId,
    selectedFacilityId,
    canListObservation,
    loadedExtentPerVital,
  ]);


  // ---------------- CarePlan post-edit refresh flow ----------------
  type CarePlanFlowState = 'idle' | 'waiting' | 'fetching' | 'error';
  const [carePlanFlow, setCarePlanFlow] = useState<{ state: CarePlanFlowState; message: string }>({
    state: 'idle',
    message: '',
  });
  const carePlanTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const carePlanRetryCountRef = useRef(0);

  const clearCarePlanTimer = () => {
    if (carePlanTimerRef.current) {
      clearTimeout(carePlanTimerRef.current);
      carePlanTimerRef.current = null;
    }
  };

  const fetchCarePlanOnce = async () => {
    try {
      setCarePlanFlow({ state: 'fetching', message: 'Fetching updated care plan…' });

      const body = buildBody('CarePlan');
      const bundle = await fhirRequest({ resourceType: 'CarePlan', selectedFacilityId, body });
      const hasEntries = Array.isArray(bundle?.entry) && bundle.entry.length > 0;

      setTabBundle('carePlan', bundle);

      if (hasEntries) {
        setCarePlanFlow({ state: 'idle', message: '' });
        carePlanRetryCountRef.current = 0;
        clearCarePlanTimer();
      } else {
        if (carePlanRetryCountRef.current < 1) {
          carePlanRetryCountRef.current += 1;
          setCarePlanFlow({
            state: 'waiting',
            message: 'Fetching care plan. This may take a few moments…',
          });
          clearCarePlanTimer();
          carePlanTimerRef.current = setTimeout(fetchCarePlanOnce, 10000);
        } else {
          setCarePlanFlow({
            state: 'error',
            message: 'Careplan being updated. Please try refreshing again',
          });
          clearCarePlanTimer();
        }
      }
    } catch (e: any) {
      setCarePlanFlow({
        state: 'error',
        message: e?.message || 'Something went wrong fetching care plan.',
      });
      clearCarePlanTimer();
    }
  };

  const startCarePlanRefreshFlow = () => {
    carePlanRetryCountRef.current = 0;
    setCarePlanFlow({ state: 'waiting', message: 'Fetching updated care plan…' });
    clearCarePlanTimer();
    carePlanTimerRef.current = setTimeout(fetchCarePlanOnce, 5000);
  };

  useEffect(() => {
    return () => {
      clearCarePlanTimer();
    };
  }, []);

