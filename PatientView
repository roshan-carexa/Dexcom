const buildContactAddress = (c: EmergencyContact): string | null => {
  const lineParts = [c.addressLine1, c.addressLine2, c.addressLine3]
    .filter(Boolean)
    .map(part => part!.trim())
    .filter(Boolean);

  const cityStateZip = [c.city, c.state, c.postalCode]
    .filter(Boolean)
    .map(part => part!.trim())
    .filter(Boolean)
    .join(', ');

  const country = c.country?.trim();

  const segments = [
    ...lineParts,
    cityStateZip || null,
    country || null,
  ].filter(Boolean) as string[];

  if (segments.length === 0) return null;

  return segments.join(', ');
};

const formatContactTypes = (types?: EmergencyContactType[]) => {
  if (!types || types.length === 0) return [];

  const seen = new Set<string>();
  const out: string[] = [];

  for (const t of types) {
    const ct = (t.contactType || '').trim();
    const st = (t.standardContactType || '').trim();

    const text = ct && st ? `${ct} (${st})` : (ct || st);
    if (!text) continue;

    if (!seen.has(text)) {
      seen.add(text);
      out.push(text);
    }
  }
  return out;
};

