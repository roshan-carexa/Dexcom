            {
              resourceType: 'Observation',
              effectiveDateTime: iso,
              valueQuantity: { value, unit: 'bpm' },
            },
            {
              vitalTypeCode: '8867-4',
              eventId: data?.eventId ?? `${patientId}-heartRate-${iso}`,
              measurementKey: 'heartRate',
              valueNum: value,
              unit: 'bpm',
              measuredAt: iso,
            }
          );
        }

        if (measurements?.bodyWeight?.value != null) {
          const value = measurements.bodyWeight.value;

          push(
            'bodyWeight',
            {
              resourceType: 'Observation',
              effectiveDateTime: iso,
              valueQuantity: { value, unit: 'lbs' },
            },
            {
              vitalTypeCode: '29463-7',
              eventId: data?.eventId ?? `${patientId}-bodyWeight-${iso}`,
              measurementKey: 'bodyWeight',
              valueNum: value,
              unit: 'lbs',
              measuredAt: iso,
            }
          );
        }

        if (measurements?.bodyTemperature?.value != null) {
          const value = measurements.bodyTemperature.value;

          push(
            'bodyTemperature',
            {
              resourceType: 'Observation',
              effectiveDateTime: iso,
              valueQuantity: { value, unit: '°F' },
            },
            {
              vitalTypeCode: '8310-5',
              eventId: data?.eventId ?? `${patientId}-bodyTemperature-${iso}`,
              measurementKey: 'bodyTemperature',
              valueNum: value,
              unit: '°F',
              measuredAt: iso,
            }
          );
        }

        if (measurements?.painLevel?.value != null) {
          const value = measurements.painLevel.value;

          push(
            'painLevel',
            {
              resourceType: 'Observation',
              effectiveDateTime: iso,
              valueQuantity: { value, unit: '' },
            },
            {
              vitalTypeCode: '72514-3',
              eventId: data?.eventId ?? `${patientId}-painLevel-${iso}`,
              measurementKey: 'painLevel',
              valueNum: value,
              unit: '',
              measuredAt: iso,
            }
          );
        }

        if (measurements?.respirations?.value != null) {
          const value = measurements.respirations.value;

          push(
            'respiration',
            {
              resourceType: 'Observation',
              effectiveDateTime: iso,
              valueQuantity: { value, unit: 'breaths/min' },
            },
            {
              vitalTypeCode: '9279-1',
              eventId: data?.eventId ?? `${patientId}-respiration-${iso}`,
              measurementKey: 'respiration',
              valueNum: value,
              unit: 'breaths/min',
              measuredAt: iso,
            }
          );
        }

        const sys = measurements?.systolic?.value;
        const dia = measurements?.diastolic?.value;

        if (sys != null && dia != null) {
          push(
            'bloodPressure',
            {
              resourceType: 'Observation',
              effectiveDateTime: iso,
              component: [
                {
                  code: { coding: [{ code: '8480-6' }] },
                  valueQuantity: { value: sys, unit: 'mmHg' },
                },
                {
                  code: { coding: [{ code: '8462-4' }] },
                  valueQuantity: { value: dia, unit: 'mmHg' },
                },
              ],
            },
            [
              {
                vitalTypeCode: '8480-6',
                eventId: data?.eventId ?? `${patientId}-systolic-${iso}`,
                measurementKey: 'systolic',
                valueNum: sys,
                unit: 'mmHg',
                measuredAt: iso,
              },
              {
                vitalTypeCode: '8462-4',
                eventId: data?.eventId ?? `${patientId}-diastolic-${iso}`,
                measurementKey: 'diastolic',
                valueNum: dia,
                unit: 'mmHg',
                measuredAt: iso,
              },
            ]
          );
        }
      });
      try {
        await conn.start();
        await conn.invoke('SubscribeToPatient', patientId);
        connectionRef.current = conn;
      } catch (e) {
        console.error('VitalsHub connection error:', e);
      }
    })();
    return () => {
      isMounted = false;
      connectionRef.current?.stop().catch(() => { });
    };

  }, [patientId, baseurl, canListObservation, upsertLatestVitalInSummaryAnalytics]);

  //handle period channge
  useEffect(() => {
