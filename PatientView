// helper to compute date lower bound
const getDateGtISO = (p: Period): string => {
  const now = dayjs.utc(); // current time in UTC
  if (p === 'today') return now.startOf('day').format('YYYY-MM-DD');
  if (p === 'week') return now.subtract(7, 'day').format('YYYY-MM-DD');
  if (p === 'month') return now.subtract(1, 'month').format('YYYY-MM-DD');
  if (p === 'year') return now.subtract(1, 'year').format('YYYY-MM-DD');

  return now.subtract(10, 'year').format('YYYY-MM-DD');
};


