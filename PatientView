  const upsertLatestVitalInSummaryAnalytics = useCallback(
    (reading: VitalReading) => {
      setSummaryAnalytics(prev => {
        if (!prev) return prev;

        let foundLatestMeasure = false;

        const nextResults = prev.results.map((measure) => {
          if (measure.measure !== "latestVitalsByType") return measure;

          foundLatestMeasure = true;

          const oldData = Array.isArray(measure.data) ? measure.data : [];

          // Remove any old reading with the same measurementKey OR same vitalTypeCode.
          const filtered = oldData.filter(
            (x) =>
              !(
                x.measurementKey === reading.measurementKey ||
                x.vitalTypeCode === reading.vitalTypeCode
              )
          );

          return {
            ...measure,
            total: filtered.length + 1,
            data: [reading, ...filtered],
          };
        });

        if (!foundLatestMeasure) {
          nextResults.push({
            measure: "latestVitalsByType",
            type: "LATEST",
            total: 1,
            data: [reading],
          });
        }

        return {
          ...prev,
          size: nextResults.length,
