    const already = loadedExtentPerVital[selectedVital] || 'today';
    if (extentRank[period] <= extentRank[already]) {
      setVitalLoadingScoped(false);
      setVitalErrorScoped(null);
      return;
    }

    const source = axios.CancelToken.source();
    let mounted = true;

    (async () => {
      try {
        setVitalErrorScoped(null);
        setVitalLoadingScoped(true);

        const dateGtISO = getDateGtISO(period);
        const code = VITAL_CODES[selectedVital];

        const bundle = await fetchTotalObservation({
          patientId,
          selectedFacilityId,
          code,
          dateGtISO,
          cancelToken: source.token,
        });

        if (!mounted) return;

        setRawVitals(prev => ({ ...prev, [selectedVital]: bundle }));
        setVitalsData(prev => ({ ...prev, [selectedVital]: bundle }));

        setLoadedExtentPerVital(prev => ({
          ...prev,
          [selectedVital]: period,
        }));
      } catch (err: any) {
        if (!mounted) return;
        setVitalErrorScoped(err?.message || 'Failed to fetch selected vital.');
      } finally {
        if (mounted) setVitalLoadingScoped(false);
      }
    })();

    return () => {
      mounted = false;
      source.cancel('unmounted');
    };
